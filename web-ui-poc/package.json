{
  "name": "parseltongue-web-ui-poc",
  "version": "0.0.1",
  "description": "Proof of concept for 3D CodeCity visualization",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/three": "^0.160.0",
    "@vitest/ui": "^1.2.1",
    "jsdom": "^24.0.0",
    "playwright": "^1.57.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.2.1"
  }
}
