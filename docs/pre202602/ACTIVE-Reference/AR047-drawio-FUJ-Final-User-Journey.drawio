                <mxCell id="p5_q1_bg_t" value="QUERY 1: Search entities fuzzy — &quot;Find all auth-related functions&quot;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="62" y="78" width="1756" height="22" as="geometry"/>
