                <mxCell id="p5_hdr_t" value="MCP PHASE 3: QUERY — L3 + CONTRACT BLOCKS" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
