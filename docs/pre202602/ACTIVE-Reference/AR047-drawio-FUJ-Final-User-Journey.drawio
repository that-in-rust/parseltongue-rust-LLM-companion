    <diagram name="07-Data-Type-Boundaries" id="p7">
        <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1900" pageHeight="1400" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p7_hdr" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="20" y="20" width="1840" height="1320" as="geometry"/>
                </mxCell>
                <mxCell id="p7_hdr_t" value="DATA TYPE BOUNDARY REFERENCE — All structs crossing crate boundaries" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#6a1aaf;" vertex="1" parent="1">
                    <mxGeometry x="32" y="28" width="1816" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p7_ek" value="EntityKey (newtype — crosses ALL crate boundaries)&#10;&#10;struct EntityKey(String);&#10;Format: language|||kind|||scope|||name|||file_path|||discriminator&#10;&#10;Built by: build_entity_key_canonical()&#10;Validation: EntityKey::parse(s: &amp;str) -&gt; Result&lt;EntityKey, KeyError&gt;&#10;&#10;Gate G1: line numbers NEVER in key&#10;Gate G4: file_path always normalized to project-relative form" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="660" y="70" width="560" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="p7_b1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="50" y="300" width="860" height="480" as="geometry"/>
                </mxCell>
                <mxCell id="p7_b1_t" value="rust-llm-tree-extractor → rust-llm-store-runtime" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#1a7a1a;" vertex="1" parent="1">
                    <mxGeometry x="62" y="308" width="836" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p7_entity" value="struct Entity {&#10;    key:         EntityKey,&#10;    kind:        EntityKind,  // fn|struct|impl|use|component|interface|..&#10;    language:    Language,    // Rust|TypeScript|JavaScript|Ruby|C|Cpp|..&#10;    file:        String,      // normalized relative path&#10;    start_line:  u32,         // 1-indexed&#10;    end_line:    u32,&#10;    is_public:   bool,&#10;    token_count: u32,&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="360" width="380" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="p7_edge" value="struct Edge {&#10;    from:       EntityKey,&#10;    to:         EntityKey,&#10;    kind:       EdgeKind,     // calls|imports|shared_context|&#10;                              // public_module_context|implements|&#10;                              // http_boundary|ffi_boundary|..&#10;    confidence: f32,          // 1.0 structural; scored cross-lang&#10;    uncertain:  bool,         // true if conf in [0.60, 0.80)&#10;    metadata:   serde_json::Value,&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="490" y="360" width="380" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="p7_b2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="950" y="300" width="880" height="480" as="geometry"/>
                </mxCell>
                <mxCell id="p7_b2_t" value="rust-llm-rust-semantics → rust-llm-store-runtime" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="962" y="308" width="856" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p7_tce" value="struct TypedCallEdge {&#10;    from:       EntityKey,   // caller&#10;    to:         EntityKey,   // callee&#10;    kind:       TypedCallKind,&#10;                 // Direct | TraitMethod&#10;                 // DynDispatch | ClosureInvoke&#10;    confidence: f32,   // always 1.0 (ra resolved)&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="980" y="360" width="380" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="p7_impl" value="struct ImplEdge {&#10;    impl_key:   EntityKey,  // impl block&#10;    struct_key: EntityKey,  // concrete type&#10;    trait_key:  EntityKey,  // trait being impl'd&#10;    kind:       EdgeKind,   // EdgeKind::Implements&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1390" y="360" width="380" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p7_b3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="50" y="820" width="860" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="p7_b3_t" value="rust-llm-store-runtime → rust-llm-graph-reasoning (Datalog base relations)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="62" y="828" width="836" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p7_dl" value="// Ascent Datalog relations (type-safe at compile time)&#10;&#10;relation entity(EntityKey, EntityKind, Language);&#10;relation edge(EntityKey, EntityKey, EdgeKind, f32);  // f32 = confidence&#10;&#10;// These are the ONLY facts graph-reasoning reads.&#10;// All Datalog rules operate on these two base relations only." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="870" width="780" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p7_b4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="950" y="820" width="880" height="480" as="geometry"/>
                </mxCell>
                <mxCell id="p7_b4_t" value="rust-llm-graph-reasoning → rust-llm-interface-gateway (query results)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="962" y="828" width="856" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p7_br" value="struct BlastRadiusResult {&#10;    hops:    Vec&lt;HopGroup&gt;,&#10;    summary: ImpactSummary,&#10;}&#10;&#10;struct HopGroup {&#10;    n:        u32,&#10;    entities: Vec&lt;EntitySummary&gt;,&#10;    crossing: Option&lt;CrossingKind&gt;,&#10;}&#10;&#10;struct ImpactSummary {&#10;    by_language:        HashMap&lt;Language, u32&gt;,&#10;    language_crossings: u32,&#10;    total:              u32,&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
