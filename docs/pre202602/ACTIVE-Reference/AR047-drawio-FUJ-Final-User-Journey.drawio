                <mxCell id="p4_p9" value="Write to rust-llm-store-runtime&#10;single write path, no direct storage in pipeline&#10;all entities + edges committed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="50" y="950" width="500" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p4_pe_p4_p9" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="p4_p8" target="p4_p9" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p4_p10" value="Ingest Complete Response&#10;846 entities, 5418 edges, 94.6% token savings&#10;Claude shows stats to user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="50" y="1060" width="500" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p4_pe_p4_p10" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="p4_p9" target="p4_p10" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p4_c1" value="CONTRACT: extract_entities_from_file&#10;CRATE: rust-llm-tree-extractor&#10;DATA IN:  FileBytes { path, lang, content }&#10;DATA OUT: ExtractionResult { entities: Vec&lt;Entity&gt;, edges: Vec&lt;Edge&gt; }&#10;─────────────────────────&#10;WHEN lang detected THEN query lang-specific .scm&#10;SHALL not hard-error on parse fail (skip file)&#10;SHALL emit shared_context for all entity pairs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="600" y="290" width="1200" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="p4_c2" value="CONTRACT: build_entity_key_canonical&#10;CRATE: rust-llm-tree-extractor&#10;DATA IN:  KeyParts { lang, kind, scope, name, file, disc }&#10;DATA OUT: EntityKey (newtype String)&#10;─────────────────────────&#10;WHEN discriminator empty THEN key ends with |||&#10;SHALL normalize file to project-relative path (G4)&#10;SHALL never embed line numbers (G1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="600" y="440" width="1200" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="p4_c3" value="CONTRACT: detect_entity_visibility_flag&#10;CRATE: rust-llm-tree-extractor&#10;DATA IN:  VisibilityNode (tree-sitter node ref)&#10;DATA OUT: bool (is_public)&#10;─────────────────────────&#10;WHEN Rust: pub keyword present THEN true&#10;WHEN TypeScript: export keyword THEN true&#10;Pure predicate — no side effects" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="600" y="590" width="1200" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="p4_c4" value="CONTRACT: emit_shared_context_pair&#10;CRATE: rust-llm-tree-extractor&#10;DATA IN:  (Entity, Entity) same-file pair&#10;DATA OUT: Edge&lt;SharedContext&gt; { confidence: 1.0 }&#10;─────────────────────────&#10;WHEN both entities in same file THEN emit edge&#10;SHALL emit for ALL entity pairs (O(n²) per file)&#10;SHALL set confidence=1.0 always" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="600" y="670" width="1200" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="p4_c5" value="CONTRACT: emit_public_module_context&#10;CRATE: rust-llm-tree-extractor&#10;DATA IN:  (Entity, Entity) where both.is_public&#10;DATA OUT: Option&lt;Edge&lt;PublicModuleContext&gt;&gt;&#10;─────────────────────────&#10;WHEN both entities public THEN emit pub_mod_ctx edge&#10;SHALL set import_feeds_fn=true when one is import kind&#10;WHEN either is private THEN returns None" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="600" y="750" width="1200" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="p4_c6" value="CONTRACT: enrich_rust_entity_typed&#10;CRATE: rust-llm-rust-semantics&#10;DATA IN:  RustEnrichInput { entity_key, ra_db }&#10;DATA OUT: Vec&lt;TypedCallEdge&gt; { kind: Direct|TraitMethod|DynDispatch|Closure }&#10;─────────────────────────&#10;WHEN Rust file THEN load hir::Function from ra_db&#10;SHALL resolve all call sites via body_with_source_map&#10;SHALL NOT run on non-Rust files" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="600" y="830" width="1200" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="p4_c7" value="CONTRACT: resolve_trait_impl_target&#10;CRATE: rust-llm-rust-semantics&#10;DATA IN:  ImplBlock (hir::Impl)&#10;DATA OUT: Option&lt;ImplEdge { struct_key, trait_key }&gt;&#10;─────────────────────────&#10;WHEN impl Trait for Struct THEN emit Implements edge&#10;WHEN inherent impl (no trait) THEN returns None&#10;SHALL use ra_db.impl_trait() for resolution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="600" y="940" width="1200" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="p4_c8" value="CONTRACT: detect_http_boundary_edge&#10;CRATE: rust-llm-cross-boundaries&#10;DATA IN:  BoundaryCandidate { server: RouteSignal, client: FetchSignal }&#10;DATA OUT: Option&lt;Edge&lt;HttpBoundary&gt;&gt;&#10;─────────────────────────&#10;WHEN score &gt;= 0.80 THEN Some(Edge{uncertain:false})&#10;WHEN score 0.60-0.79 THEN Some(Edge{uncertain:true})&#10;WHEN score &lt; 0.40 THEN None (rejected)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="600" y="1050" width="1200" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="p4_c9" value="CONTRACT: score_boundary_confidence_signal&#10;CRATE: rust-llm-cross-boundaries&#10;DATA IN:  Vec&lt;ConfidenceSignal&gt;&#10;DATA OUT: f32 (0.0–1.0 clamped)&#10;─────────────────────────&#10;RoutePathMatch::Exact +0.40 | HttpMethodMatch +0.20&#10;HandlerNameSim +0.15 | FrameworkBonus +0.10&#10;MismatchedMethod -0.10 | SHALL clamp to [0,1]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="600" y="1160" width="1200" height="115" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram name="05-MCP-Phase3-Query-L3" id="p5">
        <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1900" pageHeight="1400" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
