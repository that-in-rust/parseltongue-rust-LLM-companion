                <mxCell id="p5_q5_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="50" y="1030" width="1780" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q5_bg_t" value="QUERY 5: Public module context — &quot;Full public API surface of handle_auth_request's file&quot;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="62" y="1038" width="1756" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q5_call" value="TOOL: get_entity_detail_view → filter public_module_context edges&#10;ARGS: { &quot;key&quot;: &quot;rust|||fn|||...|||handle_auth_request|||backend/src/api/auth.rs|||&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="1070" width="500" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q5_resp" value="RESPONSE:&#10;4 public siblings: login_handler (fn), AuthRouter (struct),&#10;use axum::Json (import, feeds co-located pub fns), use AppError (import)&#10;3 private helpers: shared_context only, not in public surface" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="610" y="1070" width="560" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q5_ct" value="CONTRACT: get_public_module_siblings&#10;CRATE: rust-llm-store-runtime&#10;IN:  EntityKey (anchor entity)&#10;OUT: Vec&lt;EntitySummary&gt; (public siblings in same file)&#10;---&#10;WHEN anchor is public THEN return pub_mod_ctx siblings&#10;WHEN anchor is private THEN Vec::new()&#10;SHALL NOT include anchor itself or private siblings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1200" y="1070" width="580" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q5_e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p5_q5_call" target="p5_q5_resp" parent="1">
