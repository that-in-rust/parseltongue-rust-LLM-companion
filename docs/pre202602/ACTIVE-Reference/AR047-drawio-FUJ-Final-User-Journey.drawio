        </mxGraphModel>
    </diagram>
    <diagram name="06-Tauri-Journey" id="p6">
        <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1900" pageHeight="1400" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p6_hdr" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="20" y="20" width="1840" height="1300" as="geometry"/>
                </mxCell>
                <mxCell id="p6_hdr_t" value="TAURI APP JOURNEY — Visual CLI Launcher Philosophy" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#1a7a1a;" vertex="1" parent="1">
                    <mxGeometry x="32" y="28" width="1816" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_phi" value="TAURI PHILOSOPHY: Visual CLI launcher, NOT a replacement.&#10;Every UI action shows its CLI equivalent. Power users graduate to pure CLI within 7 days.&#10;The app teaches by example — it exists to remove the barrier to entry, not to replace the terminal." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="50" y="70" width="1760" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p6_l1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="50" y="170" width="1760" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p6_l1_t" value="L1 — THREE-PHASE OVERVIEW" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#1a7a1a;" vertex="1" parent="1">
