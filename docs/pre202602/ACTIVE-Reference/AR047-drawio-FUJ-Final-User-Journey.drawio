                <mxCell id="p5_q1_call" value="TOOL: search_entities_fuzzy_query&#10;ARGS: { &quot;query&quot;: &quot;auth&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="110" width="500" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q1_resp" value="RESPONSE:&#10;5 entities returned: handle_auth_request (rust::fn), auth_middleware (rust::fn),&#10;fetchAuthData (ts::fn), AuthGuard (ts::component), useAuth (ts::fn)&#10;Ranked: exact &gt; prefix &gt; contains. Case-insensitive. Cross-language in one pass." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="610" y="110" width="560" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q1_ct" value="CONTRACT: get_entities_fuzzy_query&#10;CRATE: rust-llm-store-runtime&#10;IN:  FuzzyQueryInput { query: String, max_results: Option&lt;u32&gt; }&#10;OUT: Vec&lt;EntitySummary&gt;&#10;---&#10;WHEN query.len()&gt;=1 THEN trigram scan on entity name&#10;SHALL rank exact&gt;prefix&gt;contains, case-insensitive&#10;WHEN no matches THEN Vec::new() (never error)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1200" y="110" width="580" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q1_e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p5_q1_call" target="p5_q1_resp" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q2_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="50" y="310" width="1780" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q2_bg_t" value="QUERY 2: Cross-language boundary — &quot;What React components call the Rust auth endpoint?&quot;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="62" y="318" width="1756" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q2_call" value="TOOL: list_cross_language_boundaries + get_callers_reverse_graph&#10;ARGS: { &quot;min_confidence&quot;: 0.60 } → { &quot;key&quot;: &quot;ts|||fn|||...|||fetchAuthData|||...&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="350" width="500" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q2_resp" value="RESPONSE:&#10;Boundary: handle_auth_request (rust) → fetchAuthData (ts) via POST /api/auth, conf=0.90&#10;Callers of fetchAuthData: LoginForm (component), useAuth (fn)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="610" y="350" width="560" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q2_ct" value="CONTRACT: list_cross_language_all&#10;CRATE: rust-llm-store-runtime&#10;IN:  CrossLangQuery { min_confidence: f32 }&#10;OUT: Vec&lt;CrossLangEdge { from, to, kind, confidence, uncertain, metadata }&gt;&#10;---&#10;WHEN min_conf=0.60 THEN high+medium edges&#10;SHALL set uncertain=true for confidence in [0.60,0.80)&#10;SHALL NOT include same-language edges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1200" y="350" width="580" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q2_e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p5_q2_call" target="p5_q2_resp" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q3_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="50" y="550" width="1780" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q3_bg_t" value="QUERY 3: Blast radius — &quot;If I change handle_auth_request, what breaks?&quot;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="62" y="558" width="1756" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q3_call" value="TOOL: analyze_blast_radius_impact&#10;ARGS: { &quot;key&quot;: &quot;rust|||fn|||...|||handle_auth_request|||...&quot;, &quot;hops&quot;: 3 }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="590" width="500" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q3_resp" value="RESPONSE:&#10;8 entities impacted: 3 Rust (auth_middleware, validate_user + root) + 5 TS (fetchAuthData, LoginForm, useAuth, Navbar, App)&#10;1 language crossing: POST /api/auth http_boundary at hop 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="610" y="590" width="560" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q3_ct" value="CONTRACT: analyze_blast_radius_hops&#10;CRATE: rust-llm-graph-reasoning (Ascent Datalog)&#10;IN:  BlastRadiusInput { root: EntityKey, max_hops: u32 }&#10;OUT: BlastRadiusResult { hops: Vec&lt;HopGroup&gt;, summary: ImpactSummary }&#10;---&#10;WHEN root has no edges THEN hops=[HopGroup{n:0}], total=1&#10;SHALL run Ascent reachable transitive closure&#10;SHALL annotate hops crossing language boundaries with CrossingKind" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1200" y="590" width="580" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q3_e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p5_q3_call" target="p5_q3_resp" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q4_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="50" y="790" width="1780" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q4_bg_t" value="QUERY 4: Entity detail (live) — &quot;Show Rust type info for handle_auth_request&quot;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="62" y="798" width="1756" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q4_call" value="TOOL: get_entity_detail_view&#10;ARGS: { &quot;key&quot;: &quot;rust|||fn|||backend::api::auth|||handle_auth_request|||backend/src/api/auth.rs|||&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="830" width="500" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q4_resp" value="RESPONSE:&#10;Source snippet (lines 45-67) read LIVE from disk (Gate G3)&#10;Typed edges: Direct→validate_user (conf 1.0), Direct→generate_token (conf 1.0)&#10;If file moved: Err(DetailError::FileMoved) — never stale cached source" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="610" y="830" width="560" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q4_ct" value="CONTRACT: get_entity_detail_live&#10;CRATE: rust-llm-store-runtime + rust-llm-interface-gateway&#10;IN:  EntityKey&#10;OUT: EntityDetail { entity, source_snippet, typed_edges, public_module_context }&#10;---&#10;WHEN file exists THEN source_snippet = live lines[start..end] (G3)&#10;SHALL NOT return cached source (always reads disk)&#10;FileMoved/PermissionDenied → explicit Err variants" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1200" y="830" width="580" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p5_q4_e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p5_q4_call" target="p5_q4_resp" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
