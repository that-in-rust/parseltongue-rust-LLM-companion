    <diagram name="03-MCP-Phase1-Setup-L3" id="p3">
        <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1900" pageHeight="1400" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p3_hdr" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="20" y="20" width="1840" height="1300" as="geometry"/>
                </mxCell>
                <mxCell id="p3_hdr_t" value="MCP PHASE 1: SETUP — L3 Implementation Detail" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#006EAF;" vertex="1" parent="1">
                    <mxGeometry x="32" y="28" width="1816" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p3_s1" value="STEP 1: User opens Claude Desktop&#10;&#10;Claude Desktop is already installed. User wants LLM to understand their Rust+React codebase.&#10;Goal: connect Parseltongue as an MCP server." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="50" y="70" width="700" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="p3_s2" value="STEP 2: Edit claude_desktop_config.json&#10;&#10;{&#10;  &quot;mcpServers&quot;: {&#10;    &quot;parseltongue&quot;: {&#10;      &quot;command&quot;: &quot;/usr/local/bin/parseltongue-mcp&quot;,&#10;      &quot;args&quot;: [&quot;--workspace&quot;, &quot;/Users/dev/myapp&quot;]&#10;    }&#10;  }&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="50" y="200" width="700" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="p3_s3" value="STEP 3: Restart Claude Desktop&#10;&#10;Claude Desktop reads config on startup.&#10;Stdio process spawned: parseltongue-mcp --workspace /Users/dev/myapp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="50" y="410" width="700" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="p3_jrpc" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=20;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="50" y="520" width="1760" height="600" as="geometry"/>
                </mxCell>
                <mxCell id="p3_jrpc_t" value="JSON-RPC Initialization Sequence (stdio)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#6a1aaf;" vertex="1" parent="1">
                    <mxGeometry x="62" y="528" width="1736" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p3_init_req" value="→ SEND: initialize&#10;&#10;{&#10;  &quot;jsonrpc&quot;: &quot;2.0&quot;,&#10;  &quot;id&quot;: 1,&#10;  &quot;method&quot;: &quot;initialize&quot;,&#10;  &quot;params&quot;: {&#10;    &quot;protocolVersion&quot;: &quot;2024-11-05&quot;,&#10;    &quot;clientInfo&quot;: { &quot;name&quot;: &quot;Claude Desktop&quot; },&#10;    &quot;capabilities&quot;: { &quot;tools&quot;: {} }&#10;  }&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="590" width="500" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="p3_init_res" value="← RECV: initialize response&#10;&#10;{&#10;  &quot;jsonrpc&quot;: &quot;2.0&quot;,&#10;  &quot;id&quot;: 1,&#10;  &quot;result&quot;: {&#10;    &quot;protocolVersion&quot;: &quot;2024-11-05&quot;,&#10;    &quot;serverInfo&quot;: {&#10;      &quot;name&quot;: &quot;parseltongue-mcp&quot;,&#10;      &quot;version&quot;: &quot;2.0.0&quot;&#10;    },&#10;    &quot;capabilities&quot;: { &quot;tools&quot;: {} }&#10;  }&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="620" y="590" width="500" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="p3_tlist_req" value="→ SEND: tools/list&#10;&#10;{ &quot;jsonrpc&quot;:&quot;2.0&quot;, &quot;id&quot;:2,&#10;  &quot;method&quot;:&quot;tools/list&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="850" width="500" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="p3_tlist_res" value="← RECV: 16 tools&#10;&#10;ingest_codebase_from_path&#10;list_all_code_entities&#10;search_entities_fuzzy_query&#10;get_entity_detail_view&#10;list_dependency_edges_all&#10;get_callers_reverse_graph&#10;get_callees_forward_graph&#10;analyze_blast_radius_impact&#10;detect_circular_dependencies&#10;rank_complexity_hotspots&#10;list_semantic_clusters&#10;list_cross_language_boundaries&#10;get_server_health_status&#10;get_codebase_statistics&#10;analyze_strongly_connected&#10;compute_graph_centrality" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="620" y="850" width="500" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="p3_ready" value="READY STATE&#10;&#10;User sees parseltongue tools in Claude Desktop tool picker.&#10;Next: user types a command to ingest their codebase." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1160" y="590" width="580" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p3_init_req" target="p3_init_res" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p3_tlist_req" target="p3_tlist_res" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e3" value="initialized notification first" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" edge="1" source="p3_init_res" target="p3_tlist_req" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e4" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p3_tlist_res" target="p3_ready" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_note" value="GATE SUMMARY&#10;&#10;G1: Line numbers never in EntityKey&#10;G2: Single getter contract — all reads go through one fn&#10;G3: Source code always read live from disk&#10;G4: File paths normalized to project root&#10;R4: Responses use XML-tagged grouping for LLM parsing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1160" y="730" width="580" height="160" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
